<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>agentdiff — {{ title }}</title>
<style>
  :root {
    --bg:#0d1117; --panel:#161b22; --border:#30363d; --text:#e6edf3; --dim:#9198a1;
    --match:#1c2128; --sub:#3a2d12; --insert:#0f2a16; --delete:#2d1418;
    --accent:#d2a8ff; --up:#f85149; --down:#3fb950;
    --mono:ui-monospace,"SF Mono",Menlo,Consolas,monospace;
  }
  * { box-sizing:border-box; }
  body { margin:0; background:var(--bg); color:var(--text); font-family:system-ui,sans-serif; }
  header { padding:20px 24px; border-bottom:1px solid var(--border); }
  h1 { font-size:1.2rem; margin:0 0 4px; }
  h1 code { color:var(--accent); }
  .meta { color:var(--dim); font-size:.82rem; font-family:var(--mono); }
  .banner { display:flex; gap:24px; flex-wrap:wrap; padding:16px 24px; border-bottom:1px solid var(--border); background:var(--panel); }
  .stat .n { font-size:1.3rem; font-weight:700; font-family:var(--mono); }
  .stat .l { font-size:.72rem; color:var(--dim); text-transform:uppercase; letter-spacing:.04em; }
  .stat .up { color:var(--up); } .stat .down { color:var(--down); }
  .legend { display:flex; gap:16px; flex-wrap:wrap; padding:10px 24px; font-size:.78rem; color:var(--dim); border-bottom:1px solid var(--border); }
  .legend i { display:inline-block; width:12px; height:12px; border-radius:3px; margin-right:6px; vertical-align:middle; }
  .diverge-mark { padding:6px 24px; background:rgba(210,168,255,.12); color:var(--accent); font-size:.8rem; border-bottom:1px solid var(--border); }
  .cols { display:grid; grid-template-columns:48px 1fr 1fr; }
  .colhead { position:sticky; top:0; background:var(--panel); padding:8px 14px; font-size:.78rem; color:var(--dim); border-bottom:1px solid var(--border); z-index:2; }
  .gutter { color:var(--dim); font-family:var(--mono); font-size:.75rem; text-align:right; padding:10px 8px; border-bottom:1px solid var(--border); }
  .gutter.diverge { color:var(--accent); font-weight:700; }
  .cell { padding:10px 14px; border-bottom:1px solid var(--border); border-left:1px solid var(--border); cursor:pointer; }
  .cell .label { font-family:var(--mono); font-size:.72rem; color:var(--dim); }
  .cell .content { font-size:.86rem; white-space:pre-wrap; word-break:break-word; margin-top:3px; max-height:5.2em; overflow:hidden; }
  .cell.expanded .content { max-height:none; }
  .cell .detail { display:none; margin-top:8px; font-family:var(--mono); font-size:.75rem; color:var(--dim); white-space:pre-wrap; }
  .cell.expanded .detail { display:block; }
  .cell.match { background:var(--match); }
  .cell.substitute { background:var(--sub); }
  .cell.b.insert_b { background:var(--insert); } .cell.a.insert_b { opacity:.35; }
  .cell.a.delete_a { background:var(--delete); } .cell.b.delete_a { opacity:.35; }
  footer { padding:16px 24px; color:var(--dim); font-size:.78rem; }
</style>
</head>
<body>
<header>
  <h1><code>agentdiff</code> — {{ title }}</h1>
  <div class="meta">A: {{ source_a }} · B: {{ source_b }}</div>
</header>
<div class="banner" id="banner"></div>
<div class="legend">
  <span><i style="background:var(--match)"></i>match</span>
  <span><i style="background:var(--sub)"></i>changed</span>
  <span><i style="background:var(--delete)"></i>only in A</span>
  <span><i style="background:var(--insert)"></i>only in B</span>
  <span>· click any row to expand</span>
</div>
<div id="diverge" class="diverge-mark"></div>
<div class="cols">
  <div class="colhead">#</div>
  <div class="colhead">A (baseline)</div>
  <div class="colhead">B (candidate)</div>
  <div id="rows" style="display:contents"></div>
</div>
<footer>Generated by agentdiff · fully local, no external requests.</footer>

<script id="diff-data" type="application/json">{{ diff_json }}</script>
<script>
  // All user/trace content is written via textContent (never innerHTML) so a
  // malicious trace cannot inject script — stored-XSS guard.
  const diff = JSON.parse(document.getElementById("diff-data").textContent);

  const METRIC_LABELS = {
    total_tokens: "Δ tokens", cost: "Δ cost",
    latency_ms: "Δ latency (ms)", tool_calls: "Δ tool calls",
  };
  const banner = document.getElementById("banner");
  for (const [key, label] of Object.entries(METRIC_LABELS)) {
    const d = diff.deltas[key];
    if (!d || !d.available) continue;
    const v = Math.round(d.value * 1000) / 1000;
    const dir = v > 0 ? "up" : (v < 0 ? "down" : "");
    const arrow = v > 0 ? "▲" : (v < 0 ? "▼" : "·");
    const stat = document.createElement("div");
    stat.className = "stat";
    const n = document.createElement("div"); n.className = "n " + dir; n.textContent = arrow + " " + v;
    const l = document.createElement("div"); l.className = "l"; l.textContent = label;
    stat.append(n, l);
    banner.append(stat);
  }
  if (!banner.children.length) {
    banner.textContent = "No metric deltas (traces identical or metrics untracked).";
    banner.style.color = "var(--dim)";
  }

  const divIdx = diff.first_divergence_index;
  const dv = document.getElementById("diverge");
  dv.textContent = divIdx === null
    ? "✓ No divergence — the two runs align fully."
    : "First divergence at aligned row " + (divIdx + 1) + ".";

  function makeCell(side, step, op) {
    const c = document.createElement("div");
    c.className = "cell " + side + " " + op;
    if (!step) { c.innerHTML = "&nbsp;"; return c; }
    const label = document.createElement("div");
    label.className = "label";
    label.textContent = step.label + "  ·  " + step.total_tokens + " tok";
    const content = document.createElement("div");
    content.className = "content";
    content.textContent = step.content || "(empty)";
    c.append(label, content);
    if (step.tool_args) {
      const detail = document.createElement("div");
      detail.className = "detail";
      detail.textContent = "tool_args: " + JSON.stringify(step.tool_args, null, 2);
      c.append(detail);
    }
    return c;
  }

  const rows = document.getElementById("rows");
  diff.pairs.forEach((pair, idx) => {
    const gutter = document.createElement("div");
    gutter.className = "gutter" + (idx === divIdx ? " diverge" : "");
    gutter.textContent = idx + 1;
    const a = makeCell("a", pair.a, pair.op);
    const b = makeCell("b", pair.b, pair.op);
    const toggle = () => { a.classList.toggle("expanded"); b.classList.toggle("expanded"); };
    [gutter, a, b].forEach(el => { el.addEventListener("click", toggle); rows.append(el); });
  });
</script>
</body>
</html>
